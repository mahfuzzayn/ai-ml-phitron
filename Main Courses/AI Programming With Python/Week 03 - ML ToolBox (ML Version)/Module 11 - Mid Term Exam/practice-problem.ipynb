    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "df = pd.read_csv(\"./staff_data.csv\")\n",
    "\n",
    "df.drop([\"emp_id\", \"emp_age\"], axis=\"columns\", inplace=True)\n",
    "\n",
    "roles = df.pop(\"role\")\n",
    "df.insert(0, \"role\", roles)\n",
    "\n",
    "df.rename(columns={\"emp_salary\": \"previous_salary\"})\n",
    "\n",
    "\n",
    "\n",
    "df"
